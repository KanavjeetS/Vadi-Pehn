# =============================================================
# Vadi-Pehn — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================

# ── Environment Mode ──────────────────────────────────────────
# Use 'development' for local single-process mode (start_desktop.py)
# Use 'production' for docker compose
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Auth & Security (CHANGE THESE IN PRODUCTION!) ────────────
JWT_SECRET_KEY=change_me_jwt_secret_min_32_chars_required
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
INTERNAL_SERVICE_TOKEN=vadi_internal_service_secret_token_123
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080,http://127.0.0.1:8080

# ── Groq — LLM + STT inference (sub-100ms) ──────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_STT_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ── ElevenLabs — Indian female TTS ───────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Aria (Indian-accented): 9BWtsMINqrJLrRacOk9x  (recommended for Vadi)
# Rachel (default):       21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID=9BWtsMINqrJLrRacOk9x
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_SPEED=1.0

# ── Postgres — Memory Service (Supabase pgvector) ────────────
# For docker-compose: replace 'localhost' with your Supabase host
MEMORY_DB_DSN=postgresql://postgres:your_password@db.your-supabase-id.supabase.co:5432/postgres
MEMORY_DB_HOST=db.your-supabase-id.supabase.co
MEMORY_DB_PORT=5432
MEMORY_DB_NAME=postgres
MEMORY_DB_USER=postgres
MEMORY_DB_PASSWORD=your_supabase_db_password

# ── Postgres — Governance Service (SEPARATE INSTANCE per PRD) ─
GOVERNANCE_DB_DSN=postgresql://postgres:your_password@db.your-governance-supabase-id.supabase.co:5432/postgres
GOVERNANCE_DB_HOST=db.your-governance-supabase-id.supabase.co
GOVERNANCE_DB_PORT=5432
GOVERNANCE_DB_NAME=postgres
GOVERNANCE_DB_USER=postgres
GOVERNANCE_DB_PASSWORD=your_governance_db_password

# ── Supabase — Client SDK ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
SUPABASE_SECRET_KEY=your_supabase_service_role_key

# ── MongoDB Atlas — NoSQL telemetry ──────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_USERNAME=user
MONGODB_PASSWORD=password
MONGODB_DB_NAME=vadi_nosql

# ── vLLM & Safety Classifier ──────────────────────────────────
# In production: point to your vLLM / NVIDIA NIM endpoints
VLLM_MAIN_URL=http://localhost:8010
VLLM_MAIN_MODEL=google/diffusiongemma-26b-a4b-it
VLLM_MAIN_TIMEOUT_SECONDS=30
VLLM_CLASSIFIER_URL=http://localhost:8011
VLLM_CLASSIFIER_MODEL=meta-llama/Llama-Guard-3-8B
VLLM_CLASSIFIER_TIMEOUT_SECONDS=3
NVIDIA_API_KEY=your_nvidia_api_key_here

# ── Safety Proxy ──────────────────────────────────────────────
# Set SAFETY_PROXY_ALLOW_DEV_BYPASS=true ONLY in development when
# no Llama Guard container is running. MUST be false in production.
SAFETY_PROXY_ALLOW_DEV_BYPASS=true

# ── Inter-service URLs ────────────────────────────────────────
# LOCAL / start_desktop.py mode — all routes through 127.0.0.1:8080
# (start_desktop.py overrides these automatically)
SAFETY_PROXY_URL=http://127.0.0.1:8080
ORCHESTRATION_URL=http://127.0.0.1:8080
VOICE_GATEWAY_URL=http://127.0.0.1:8080
MEMORY_SERVICE_URL=http://127.0.0.1:8080
GOVERNANCE_SERVICE_URL=http://127.0.0.1:8080
PANEL_SERVICE_URL=http://127.0.0.1:8080
DASHBOARD_BFF_URL=http://127.0.0.1:8080
INGESTION_SERVICE_URL=http://127.0.0.1:8080

# DOCKER mode — set these in docker-compose environment section
# (docker-compose.yml overrides these with container names automatically)
# SAFETY_PROXY_URL=http://safety-proxy:8000
# ORCHESTRATION_URL=http://orchestration:8000
# VOICE_GATEWAY_URL=http://voice-gateway:8000
# MEMORY_SERVICE_URL=http://memory-service:8000
# GOVERNANCE_SERVICE_URL=http://governance-service:8000
# PANEL_SERVICE_URL=http://panel-service:8000
# DASHBOARD_BFF_URL=http://dashboard-bff:8000
# INGESTION_SERVICE_URL=http://ingestion-service:8000

# ── LiveKit — WebRTC SFU ──────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-domain.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# ── MinIO — Document storage ─────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=vadi-documents
MINIO_SECURE=false

# ── Langfuse — LLM Observability ─────────────────────────────
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
