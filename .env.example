# =============================================================
# Vadi-Pehn — Environment Variables
# Copy to .env and fill in actual values. NEVER commit .env.
# =============================================================

# ── Postgres (Memory Service) ──────────────────────────────
MEMORY_DB_HOST=localhost
MEMORY_DB_PORT=5432
MEMORY_DB_NAME=vadi_memory
MEMORY_DB_USER=vadi_app
MEMORY_DB_PASSWORD=change_me_memory_db

# ── Postgres (Governance Service — SEPARATE INSTANCE) ──────
GOVERNANCE_DB_HOST=localhost
GOVERNANCE_DB_PORT=5433
GOVERNANCE_DB_NAME=vadi_governance
GOVERNANCE_DB_USER=vadi_gov_app
GOVERNANCE_DB_PASSWORD=change_me_governance_db

# ── MinIO (Document Storage) ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change_me_minio_access
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_BUCKET_DOCUMENTS=vadi-documents
MINIO_SECURE=false

# ── vLLM (Main Model — Llama-3.3-70B) ─────────────────────
VLLM_MAIN_URL=http://localhost:8001
VLLM_MAIN_MODEL=meta-llama/Llama-3.3-70B-Instruct
VLLM_MAIN_TIMEOUT_SECONDS=30

# ── vLLM (Classifier — Llama-Guard-3-8B) ──────────────────
VLLM_CLASSIFIER_URL=http://vllm-classifier:8002
VLLM_CLASSIFIER_MODEL=meta-llama/Llama-Guard-3-8B
VLLM_CLASSIFIER_TIMEOUT_SECONDS=3

# ── Safety Proxy ───────────────────────────────────────────
SAFETY_PROXY_URL=http://safety-proxy:8080
SAFETY_PROXY_TIMEOUT_SECONDS=3

# ── Memory Service ─────────────────────────────────────────
MEMORY_SERVICE_URL=http://memory-service:8003

# ── Governance Service ─────────────────────────────────────
GOVERNANCE_SERVICE_URL=http://governance-service:8004

# ── Panel Service ──────────────────────────────────────────
PANEL_SERVICE_URL=http://panel-service:8005

# ── Voice Gateway ──────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=change_me_livekit_key
LIVEKIT_API_SECRET=change_me_livekit_secret
WHISPER_MODEL=large-v3
KOKORO_MODEL_PATH=/models/kokoro-82m

# ── Langfuse (Observability) ───────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=change_me_langfuse_pub
LANGFUSE_SECRET_KEY=change_me_langfuse_secret

# ── Redis (Session Store) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ───────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── On-Call / Escalation ───────────────────────────────────
ONCALL_SMS_WEBHOOK_URL=https://change_me_sms_webhook
ONCALL_PAGER_PHONE=+910000000000

# ── Deployment ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
