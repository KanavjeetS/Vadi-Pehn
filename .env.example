# =============================================================
# Vadi-Pehn — Environment Variables Example
# Copy to .env and fill in actual values. NEVER commit .env.
# =============================================================

# ── Postgres (Memory Service — Supabase pgvector instance) ──────
MEMORY_DB_DSN=postgresql://vadi_user:your_password_here@localhost:5432/vadi_memory
MEMORY_DB_HOST=localhost
MEMORY_DB_PORT=5432
MEMORY_DB_NAME=vadi_memory
MEMORY_DB_USER=postgres
MEMORY_DB_PASSWORD=your_password_here

# ── Postgres (Governance Service — SEPARATE INSTANCE) ──────
GOVERNANCE_DB_DSN=postgresql://vadi_gov_user:your_password_here@localhost:5433/vadi_governance
GOVERNANCE_DB_HOST=localhost
GOVERNANCE_DB_PORT=5433
GOVERNANCE_DB_NAME=vadi_governance
GOVERNANCE_DB_USER=postgres
GOVERNANCE_DB_PASSWORD=your_password_here

# ── MinIO (Document Storage) ───────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=vadi-documents
MINIO_SECURE=false

# ── Groq Hardware Acceleration (Sub-100ms LLM & STT) ──────
GROQ_API_KEY=your_groq_api_key_here
GROQ_STT_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# ── ElevenLabs Low-Latency Streaming TTS ─────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── LiveKit Cloud SFU WebRTC ────────────────────────────────
LIVEKIT_URL=wss://your-livekit-domain.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# ── vLLM & Safety Proxy ───────────────────────────────────
VLLM_MAIN_URL=http://localhost:8000
VLLM_MAIN_MODEL=google/diffusiongemma-26b-a4b-it
VLLM_MAIN_TIMEOUT_SECONDS=30
VLLM_CLASSIFIER_URL=http://localhost:8002
VLLM_CLASSIFIER_MODEL=meta-llama/Llama-Guard-3-8B
NVIDIA_API_KEY=your_nvidia_api_key_here
VLLM_CLASSIFIER_TIMEOUT_SECONDS=3
SAFETY_PROXY_URL=http://safety-proxy:8002
SAFETY_PROXY_TIMEOUT_SECONDS=3
SAFETY_PROXY_ALLOW_DEV_BYPASS=true

# ── Microservices Endpoints ────────────────────────────────
MEMORY_SERVICE_URL=http://memory-service:8003
GOVERNANCE_SERVICE_URL=http://governance-service:8004
PANEL_SERVICE_URL=http://panel-service:8005

# ── Langfuse (Observability) ───────────────────────────────
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=change_me_langfuse_pub
LANGFUSE_SECRET_KEY=change_me_langfuse_secret

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth & Security ────────────────────────────────────────
JWT_SECRET_KEY=change_me_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
INTERNAL_SERVICE_TOKEN=vadi_internal_service_secret_token_123

# ── Deployment ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── MongoDB Atlas (NoSQL Store & Telemetry) ─────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_USERNAME=user
MONGODB_PASSWORD=password
MONGODB_DB_NAME=vadi_nosql

# ── Supabase (Postgres & RAG RLS Client) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key
