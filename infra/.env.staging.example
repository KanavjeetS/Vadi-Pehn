# Copy to a secret-managed environment file. Never commit real values.
ENVIRONMENT=staging
JWT_SECRET_KEY=replace-with-a-long-random-secret
INTERNAL_SERVICE_TOKEN=replace-with-a-different-long-random-token
LIVEKIT_API_KEY=replace-livekit-api-key
LIVEKIT_API_SECRET=replace-livekit-api-secret
LIVEKIT_URL=wss://livekit.staging.example.org
MEMORY_DB_PASSWORD=replace-memory-db-password
GOVERNANCE_DB_PASSWORD=replace-governance-db-password
MINIO_ACCESS_KEY=replace-minio-access-key
MINIO_SECRET_KEY=replace-minio-secret-key
VLLM_MAIN_MODEL=meta-llama/Llama-3.3-70B-Instruct
VLLM_CLASSIFIER_MODEL=meta-llama/Llama-Guard-3-8B
MEMORY_EMBEDDING_URL=https://embedding.staging.example.org/v1/embeddings
MEMORY_EMBEDDING_MODEL=nomic-embed-text
SAFETY_PROXY_ALLOW_DEV_BYPASS=false
CORS_ALLOWED_ORIGINS=https://staging.example.org
ONCALL_SMS_WEBHOOK_URL=https://oncall.example.org/hooks/vadi-pehn
